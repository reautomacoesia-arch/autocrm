NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave service_role do Supabase — necessária para o cron e o webhook do WhatsApp
# (rotas sem sessão de usuário, que precisam ignorar RLS). Nunca exponha no client.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# URL do app gerador_propostas (usado pelo botão "Nova Proposta")
NEXT_PUBLIC_GERADOR_PROPOSTAS_URL=http://localhost:3002

# ---------- Agente de IA no WhatsApp (SDR virtual) ----------

# Chave da API da Anthropic (console.anthropic.com) — usada pelo agente para
# responder e qualificar leads automaticamente.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Credenciais da instância Z-API (z-api.io) usada para enviar mensagens de WhatsApp.
ZAPI_INSTANCE_ID=sua-instancia-zapi
ZAPI_TOKEN=seu-token-zapi
ZAPI_CLIENT_TOKEN=seu-client-token-zapi

# Segredo usado para validar o webhook do WhatsApp.
# Configure no Z-API a URL "Ao receber" como:
#   https://SEU_DOMINIO/api/webhooks/whatsapp?secret=WHATSAPP_WEBHOOK_SECRET
WHATSAPP_WEBHOOK_SECRET=gere-um-valor-aleatorio-longo
